<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <FrameLayout
        android:id="@+id/video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/gesture_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/gesture_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/overlay_bg"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/controls_scrim"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00 / 00:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:max="1000" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <ImageButton
                android:id="@+id/rew"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Назад 10 сек"
                app:srcCompat="@drawable/ic_fast_rewind" />

            <ImageButton
                android:id="@+id/play_pause"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Пауза / воспроизведение"
                app:srcCompat="@drawable/ic_pause" />

            <ImageButton
                android:id="@+id/fwd"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Вперёд 10 сек"
                app:srcCompat="@drawable/ic_fast_forward" />

            <ImageButton
                android:id="@+id/fwd90"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Вперёд 1:30"
                app:srcCompat="@drawable/ic_skip_next" />

            <Button
                android:id="@+id/speed"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0x"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/aspect"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Соотношение сторон"
                app:srcCompat="@drawable/ic_aspect" />

            <ImageButton
                android:id="@+id/fullscreen"
                style="@style/ControlButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="На весь экран"
                app:srcCompat="@drawable/ic_fullscreen" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
