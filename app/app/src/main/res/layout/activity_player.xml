<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/video_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/gesture_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#B3000000"
        android:gravity="center"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:singleLine="true"
        android:ellipsize="middle"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/buffering"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/overlay_bg"
        android:padding="22dp">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            style="?android:attr/progressBarStyleLarge" />

        <TextView
            android:id="@+id/buffering_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Подготовка видео…"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

        <Button
            android:id="@+id/buffer_retry"
            style="@style/PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Повторить"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/gesture_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/overlay_bg"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/controls_scrim"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00 / 00:00"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:max="1000" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton android:id="@+id/prev" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Предыдущая" app:srcCompat="@drawable/ic_skip_previous" />

                <ImageButton android:id="@+id/rew" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Назад 10 сек" app:srcCompat="@drawable/ic_fast_rewind" />

                <ImageButton android:id="@+id/play_pause" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Пауза / воспроизведение" app:srcCompat="@drawable/ic_pause" />

                <ImageButton android:id="@+id/fwd" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Вперёд 10 сек" app:srcCompat="@drawable/ic_fast_forward" />

                <ImageButton android:id="@+id/fwd90" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Вперёд 1:30" app:srcCompat="@drawable/ic_skip_forward" />

                <ImageButton android:id="@+id/next" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Следующая" app:srcCompat="@drawable/ic_skip_next" />

                <Button android:id="@+id/speed" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1.0x" android:textColor="#FFFFFF" android:textSize="14sp" />

                <ImageButton android:id="@+id/aspect" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="Соотношение сторон" app:srcCompat="@drawable/ic_aspect" />

                <ImageButton android:id="@+id/fullscreen" style="@style/ControlButton"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:contentDescription="На весь экран" app:srcCompat="@drawable/ic_fullscreen" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</FrameLayout>
