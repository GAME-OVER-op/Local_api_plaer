<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="android:Theme.Holo.Light.DarkActionBar">
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
    </style>

    <style name="AppTheme.Fullscreen" parent="android:Theme.Holo.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="PrimaryButton" parent="android:Widget.Holo.Button">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/header_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ControlButton" parent="android:Widget.Holo.Button">
        <item name="android:background">@drawable/btn_control</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:minWidth">48dp</item>
        <item name="android:padding">8dp</item>
    </style>
</resources>
